#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
e2b_dir="$(cd -- "${script_dir}/.." && pwd)"

if [[ ! -f "${e2b_dir}/dist/src/cudex-cli.js" ]]; then
  echo "cudex installation is incomplete: compiled runner is missing" >&2
  exit 2
fi

exec node "${e2b_dir}/dist/src/cudex-cli.js" "$@"
