{
  "name": "cudex-e2b-development",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate": "npm run build && node dist/src/migrate.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "start": "node dist/src/main.js",
    "poc:preflight": "npm run build && node dist/src/poc-runner.js preflight",
    "poc:automated": "npm run build && node dist/src/poc-runner.js automated",
    "poc:interactive": "npm run build && node dist/src/poc-runner.js interactive",
    "verify:template": "npm run build && node dist/src/commands/verify-template.js",
    "verify:release": "npm run build && node dist/src/commands/verify-release.js",
    "lifecycle:canary": "npm run build && node dist/src/commands/lifecycle-canary.js",
    "sql:generate": "npm run build && node dist/src/commands/generate-sql.js",
    "sql:check": "npm run build && node dist/src/commands/generate-sql.js --check"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@hono/node-server": "^2.0.10",
    "@pgtyped/runtime": "^2.4.2",
    "@t3-oss/env-core": "^0.13.11",
    "e2b": "2.35.0",
    "execa": "^10.0.0",
    "hono": "^4.12.31",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "tar": "^7.5.20",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pgtyped/cli": "^2.4.3",
    "@types/node": "^22.18.3",
    "@types/pg": "^8.15.5",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.2"
  }
}
