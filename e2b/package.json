{
  "name": "cudex-e2b-development",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate": "npm run build && node dist/src/migrate.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "start": "node dist/src/main.js",
    "poc:preflight": "npm run build && node dist/src/poc-runner.js preflight",
    "poc:automated": "npm run build && node dist/src/poc-runner.js automated",
    "poc:interactive": "npm run build && node dist/src/poc-runner.js interactive"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "e2b": "2.35.0",
    "pg": "^8.22.0",
    "tar": "^7.5.20",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^22.18.3",
    "@types/pg": "^8.15.5",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.2"
  }
}
