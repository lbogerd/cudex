E2B_API_KEY=
E2B_API_URL=
E2B_DOMAIN=cube.app
E2B_VALIDATE_API_KEY=false

# Required when the E2B/CubeSandbox API or sandbox domain uses a private CA.
POC_PROVIDER_CA_CERTIFICATE=

# Required template provenance file.
POC_TEMPLATE_METADATA=e2b/.artifacts/templates/<build-id>.json

# Configure exactly one authentication source.
CODEX_ACCESS_TOKEN=
CODEX_AUTH_JSON_FILE=e2b/poc/secrets/auth.json

# Current gpt-5.6 defaults are code-mode-only and incompatible with the POC's
# deliberately narrow direct-tool policy. Choose a listed direct-tool model.
POC_CODEX_MODEL=gpt-5.5
POC_CONTROL_PORT=18443
POC_POSTGRES_PORT=15432
POC_GARAGE_PORT=13900
POC_KEEP_ON_FAILURE=false
POC_VERIFY_TEMPLATE=false
